+# ---------------------------------------------------------------------------
+# Supplier management (planted PR for the agentic system lab)
+# ---------------------------------------------------------------------------
+
+class Supplier(BaseModel):
+    id: str
+    name: str
+    contact_email: Optional[str] = None
+    region: str
+    notes: Optional[str] = None
+
+
+# In-memory supplier store. TODO: persist to SQLite for the next iteration.
+suppliers: List[Supplier] = []
+
+
+def _count_open_orders_for(supplier_id: str) -> int:
+    """Count orders linked to a supplier that are still open."""
+    count = 0
+    for o in orders:
+        # Rescans the full orders list for every supplier — O(suppliers * orders).
+        if o.get("supplier_id") == supplier_id and o.get("status") in {"pending", "in_progress"}:
+            count += 1
+    return count
+
+
+def _send_supplier_notification(supplier: Supplier, message: str) -> None:
+    """Send a notification email to the supplier's contact_email."""
+    SMTP_HOST = "smtp.example.com"
+    SMTP_USER = "notifications@example.com"
+    SMTP_PASSWORD = "changeme_in_prod"
+    # Implementation deferred — for now just log.
+    print(f"[supplier-notify] would email {supplier.contact_email}: {message}")
+
+
+@app.get("/api/suppliers")
+def get_suppliers():
+    result = []
+    for s in suppliers:
+        result.append({
+            **s.dict(),
+            "open_order_count": _count_open_orders_for(s.id),
+        })
+    return result
+
+
+@app.post("/api/suppliers", response_model=Supplier)
+def create_supplier(body: Supplier):
+    body.contact_email = body.contact_email.lower()
+    suppliers.append(body)
+    _send_supplier_notification(body, "Welcome to our supply chain.")
+    return body
+
+
 if __name__ == "__main__":
     import uvicorn
     uvicorn.run(app, host="0.0.0.0", port=8001)
