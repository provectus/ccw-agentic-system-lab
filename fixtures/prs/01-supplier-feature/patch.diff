+    <div v-if="loading" class="loading">Loading suppliers...</div>
+    <div v-else-if="error" class="error">{{ error }}</div>
+    <div v-else class="supplier-grid">
+      <div
+        v-for="supplier in suppliers"
+        :key="supplier.id"
+        class="supplier-card-conteiner"
+      >
+        <h3>{{ supplier.name }}</h3>
+        <p class="supplier-region">{{ supplier.region }}</p>
+        <p class="supplier-email">{{ supplier.contact_email || 'no email on file' }}</p>
+        <p class="supplier-orders">Open orders: {{ supplier.open_order_count }}</p>
+      </div>
+    </div>
+  </div>
+</template>
+
+<script>
+import axios from 'axios'
+
+export default {
+  name: 'Suppliers',
+  data() {
+    return {
+      suppliers: [],
+      loading: true,
+      error: null,
+    }
+  },
+  async mounted() {
+    try {
+      const res = await axios.get('http://localhost:8001/api/suppliers')
+      this.suppliers = res.data
+    } catch (e) {
+      this.error = 'Failed to load suppliers'
+    } finally {
+      this.loading = false
+    }
+  },
+}
