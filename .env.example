# Claude Agent SDK — required
ANTHROPIC_API_KEY=your_api_key_here

# Optional. Only needed if `gh auth login` is unavailable on your machine.
# The agent prefers `gh` CLI auth; this is a fallback for raw API calls.
GITHUB_TOKEN=

# Optional overrides. Defaults live in agent/config.py.
# AGENT_MODEL_ROUTER=claude-haiku-4-5
# AGENT_MODEL_COORDINATOR=claude-sonnet-4-6
# AGENT_MODEL_WORKER=claude-opus-4-7
# AGENT_MODEL_CRITIC=claude-opus-4-7
# AGENT_TELEMETRY_DIR=./runs
# AGENT_WORKSPACE_DIR=./workspace
